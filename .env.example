# Neo Eco Cleaning — environment variables (copy to .env.local)

# Where the quote/contact form forwards submissions.
# Set to a Formspree endpoint, a webhook, or any service that accepts a JSON POST.
# If unset, /api/quote accepts and logs the submission only (no delivery). TODO before launch.
QUOTE_FORWARD_URL=

# Vertex AI media generation (scripts/generate-assets.mjs) uses Application Default Credentials.
# Override the GCP project if needed (defaults to radlabs-497004 in the script).
# GCLOUD_PROJECT=
